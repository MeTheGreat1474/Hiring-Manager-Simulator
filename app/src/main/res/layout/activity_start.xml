<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFAB76">

    <!-- ── TOP-LEFT: Laptop (rotated, partially off-screen) ── -->
    <ImageView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-30dp"
        android:layout_marginTop="-20dp"
        android:src="@drawable/ic_laptop"
        android:rotation="-15"
        android:scaleType="fitCenter"
        android:contentDescription="laptop" />

    <!-- ── TOP-RIGHT: Coffee cup ── -->
    <ImageView
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_coffee"
        android:rotation="10"
        android:scaleType="fitCenter"
        android:contentDescription="coffee" />

    <!-- ── BOTTOM-LEFT: Notebook ── -->
    <ImageView
        android:layout_width="160dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-10dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_notebook"
        android:rotation="10"
        android:scaleType="fitCenter"
        android:contentDescription="notebook" />

    <!-- ── BOTTOM-RIGHT: Pen, pencil, sticky notes ── -->
    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-10dp"
        android:layout_marginBottom="10dp"
        android:src="@drawable/ic_pen_pencil"
        android:rotation="-5"
        android:scaleType="fitCenter"
        android:contentDescription="stationery" />

    <!-- ── CENTER: Clipboard ── -->
    <FrameLayout
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_clipboard_board">

        <!-- Cream paper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="54dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_clipboard_paper"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HIRING MANAGER\nSIMULATOR"
                android:textColor="#1A1A1A"
                android:fontFamily="@font/courier_prime"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:paddingBottom="32dp"
                android:paddingTop="16dp" />

            <!-- Start button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_start_game"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="START GAME"
                android:background="@drawable/btn_approve"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/courier_prime"
                android:textSize="17sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:letterSpacing="0.08" />

        </LinearLayout>

        <!-- Metal clip assembly -->
        <FrameLayout
            android:layout_width="76dp"
            android:layout_height="46dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp">

            <!-- Knob -->
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_clip_knob" />

            <!-- Grip bar -->
            <View
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@drawable/bg_clip_bar" />

        </FrameLayout>

    </FrameLayout>

</FrameLayout>
