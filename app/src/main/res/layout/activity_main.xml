<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ═══════════════════════════════════════════════ -->
    <!-- MAIN CONTENT: Top Bar + Resume + Bottom Bar     -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP STATUS BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_topbar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_day_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Day 1"
                    android:textColor="@color/border_gold"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_day_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mon, 14 Oct"
                    android:textColor="@color/text_dim"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HIRING DEPT."
                android:textColor="@color/text_primary"
                android:fontFamily="@font/courier_prime"
                android:textSize="17sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="end">
                <TextView
                    android:id="@+id/tv_bonus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RM 0.00"
                    android:textColor="@color/highlight_yellow"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daily Bonus"
                    android:textColor="@color/text_dim"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <!-- APPLICANT HEADER STRIP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:background="@color/bg_ui"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp">

            <!-- Spacer to balance timer on the right -->
            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/highlight_yellow"
                android:fontFamily="@font/courier_prime"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="start"
                android:visibility="invisible" />

            <TextView
                android:id="@+id/tv_applicant_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Applicant #01 of 08"
                android:textColor="@color/text_dim"
                android:fontFamily="@font/inter"
                android:textSize="14sp"
                android:gravity="center" />

            <!-- Countdown timer (right side) -->
            <TextView
                android:id="@+id/tv_timer_right"
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/highlight_yellow"
                android:fontFamily="@font/courier_prime"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="end"
                android:visibility="invisible" />

        </LinearLayout>

        <!-- RESUME SCROLL AREA -->
        <ScrollView
            android:id="@+id/resume_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="6dp"
            android:scrollbarThumbVertical="@color/border_gold">

            <LinearLayout
                android:id="@+id/resume_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_paper"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- ══ HEADER ══ -->
                <TextView
                    android:id="@+id/tv_applicant_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tv_applicant_role"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="2dp" />

                <TextView
                    android:id="@+id/tv_applicant_contact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingTop="3dp"
                    android:paddingBottom="10dp" />

                <!-- ══ SECTION: PROFESSIONAL EXPERIENCE ══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PROFESSIONAL EXPERIENCE"
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_text"
                    android:layout_marginBottom="6dp" />

                <!-- Job entries injected here dynamically -->
                <LinearLayout
                    android:id="@+id/container_jobs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="4dp" />

                <!-- ══ SECTION: EDUCATION ══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="EDUCATION"
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_text"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tv_university"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/paper_text"
                        android:fontFamily="@font/tinos"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_university_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/paper_text"
                        android:fontFamily="@font/tinos"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="10dp">
                    <TextView
                        android:id="@+id/tv_degree"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/paper_text"
                        android:fontFamily="@font/tinos"
                        android:textSize="15sp"
                        android:textStyle="italic" />
                    <TextView
                        android:id="@+id/tv_grad_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/paper_text"
                        android:fontFamily="@font/tinos"
                        android:textSize="15sp"
                        android:textStyle="italic" />
                </LinearLayout>

                <!-- ══ SECTION: ADDITIONAL INFORMATION ══ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ADDITIONAL INFORMATION"
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/paper_text"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tv_tech_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:paddingBottom="3dp"
                    android:lineSpacingExtra="1dp" />

                <TextView
                    android:id="@+id/tv_certifications"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:paddingBottom="3dp"
                    android:lineSpacingExtra="1dp" />

                <TextView
                    android:id="@+id/tv_grade"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:paddingBottom="3dp"
                    android:lineSpacingExtra="1dp" />

                <TextView
                    android:id="@+id/tv_permit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:paddingBottom="3dp"
                    android:lineSpacingExtra="1dp" />

                <TextView
                    android:id="@+id/tv_languages"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/paper_text"
                    android:fontFamily="@font/tinos"
                    android:textSize="13sp"
                    android:paddingBottom="4dp"
                    android:lineSpacingExtra="1dp" />

                <!-- tv_skills kept for backward compat but hidden; data now split above -->
                <TextView
                    android:id="@+id/tv_skills"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="" />

            </LinearLayout>
        </ScrollView>

        <!-- BOTTOM ACTION BAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_bottombar"
            android:orientation="horizontal"
            android:padding="6dp"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_reject"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="✗  REJECT"
                android:background="@drawable/btn_reject"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/courier_prime"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:letterSpacing="0.05" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_approve"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="✓  APPROVE"
                android:background="@drawable/btn_approve"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/courier_prime"
                android:textSize="15sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:letterSpacing="0.05" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- LEFT PANEL — TOOLS (on right side)              -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/left_panel"
        android:visibility="gone"
        android:layout_width="192dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:elevation="8dp"
        android:background="@drawable/bg_panel"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="══ SKILLS ══"
            android:textColor="#5B9BD5"
            android:fontFamily="@font/courier_prime"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <!-- Skills by role — scrollable -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Programmer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PROGRAMMER"
                    android:textColor="#5B9BD5"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Python · Java · Kotlin\nReact · JavaScript · C++\nDocker · Kubernetes"
                    android:textColor="#CCCCCC"
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="8dp" />

                <!-- Data Analyst -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DATA ANALYST"
                    android:textColor="#5B9BD5"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Power BI · Excel · SQL\nTableau · Python · R\nSPSS · Google Sheets"
                    android:textColor="#CCCCCC"
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="8dp" />

                <!-- DevOps / Cloud -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DEVOPS / CLOUD"
                    android:textColor="#5B9BD5"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AWS · GCP · Azure\nDocker · Kubernetes\nTerraform · CI/CD"
                    android:textColor="#CCCCCC"
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="8dp" />

                <!-- ML Engineer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ML ENGINEER"
                    android:textColor="#5B9BD5"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TensorFlow · PyTorch\nScikit-learn · Python\nR · Spark · SQL"
                    android:textColor="#CCCCCC"
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="8dp" />

                <!-- Mobile Dev -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="MOBILE DEV"
                    android:textColor="#5B9BD5"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:paddingBottom="2dp" />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kotlin · Swift · Java\nFlutter · React Native\nAndroid SDK · iOS SDK"
                    android:textColor="#CCCCCC"
                    android:fontFamily="@font/inter"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp"
                    android:paddingBottom="4dp" />

            </LinearLayout>
        </ScrollView>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border_dark" android:layout_marginBottom="10dp"
            android:layout_marginTop="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODAY'S RECORD"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/courier_prime"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingBottom="6dp" />

        <TextView
            android:id="@+id/tv_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPROVED :  00\nREJECTED :  00\nMISTAKES :  00\nPENDING  :  00"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/inter"
            android:textSize="12sp"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- RIGHT PANEL — RULES                             -->
    <!-- ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/right_panel"
        android:layout_width="192dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:elevation="8dp"
        android:background="@drawable/bg_panel_right"
        android:paddingStart="8dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="══ MEMO ══"
            android:textColor="#4DB868"
            android:fontFamily="@font/courier_prime"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="10dp" />

        <TextView
            android:id="@+id/tv_rules_day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OBJECTIVES ─ DAY 1"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/courier_prime"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="5dp" />

        <TextView
            android:id="@+id/tv_rules_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:fontFamily="@font/courier_prime"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:paddingBottom="10dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border_dark" android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MISTAKES REMAINING"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/courier_prime"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingBottom="5dp" />

        <TextView
            android:id="@+id/tv_mistakes_left"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="●  ●  ●"
            android:textColor="#FF6B6B"
            android:fontFamily="@font/courier_prime"
            android:textSize="18sp"
            android:paddingBottom="10dp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- FLOATING TAB PILLS                                      -->
    <!-- ═══════════════════════════════════════════════════════ -->

    <FrameLayout
        android:id="@+id/right_tab_handle"
        android:layout_width="36dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="174dp"
        android:background="@drawable/ic_flag_green"
        android:elevation="12dp"
        android:clipChildren="false"
        android:clipToPadding="false">
        <TextView
            android:layout_width="72dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:rotation="90"
            android:text="MEMO"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/courier_prime"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true" />
    </FrameLayout>

    <FrameLayout
        android:id="@+id/left_tab_handle"
        android:visibility="gone"
        android:layout_width="36dp"
        android:layout_height="72dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="100dp"
        android:background="@drawable/ic_flag_blue"
        android:elevation="12dp"
        android:clipChildren="false"
        android:clipToPadding="false">
        <TextView
            android:layout_width="72dp"
            android:layout_height="26dp"
            android:layout_gravity="center"
            android:rotation="90"
            android:text="SKILLS"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/courier_prime"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:singleLine="true" />
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- DAY BRIEFING — POST-IT NOTE OVERLAY                     -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/briefing_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1A1A1A"
        android:visibility="gone"
        android:clickable="true">

        <!-- Post-it note card -->
        <LinearLayout
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:background="#FEFB8A"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:elevation="16dp">

            <!-- Tape strip at top -->
            <View
                android:layout_width="60dp"
                android:layout_height="14dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:background="#CCDDBB44"
                android:alpha="0.7" />

            <!-- Day label -->
            <TextView
                android:id="@+id/tv_briefing_day"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="DAY 1 BRIEFING"
                android:textColor="#3A2A00"
                android:fontFamily="@font/courier_prime"
                android:textSize="19sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="4dp" />

            <!-- "From HR" subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MEMO FROM HR DEPARTMENT"
                android:textColor="#7A5C00"
                android:fontFamily="@font/courier_prime"
                android:textSize="13sp"
                android:gravity="center"
                android:paddingBottom="14dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CC9922"
                android:layout_marginBottom="12dp" />

            <!-- Today's rules — scrollable -->
            <ScrollView
                android:id="@+id/briefing_scroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fadeScrollbars="false">

                <TextView
                    android:id="@+id/tv_briefing_rules"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#3A2A00"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="15sp"
                    android:lineSpacingExtra="5dp"
                    android:paddingBottom="16dp" />

            </ScrollView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CC9922"
                android:layout_marginBottom="14dp" />

            <!-- Dismiss button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_briefing_dismiss"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="UNDERSTOOD — BEGIN"
                android:background="#CC9922"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/courier_prime"
                android:textSize="16sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:letterSpacing="0.04" />

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- DECISION FEEDBACK OVERLAY                               -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/feedback_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="false">

        <TextView
            android:id="@+id/tv_feedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text=""
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="@font/courier_prime"
            android:textColor="#FFFFFF"
            android:background="#CC000000"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp" />

    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- END-OF-DAY / GAME OVER OVERLAY                         -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/end_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true">

        <!-- Clipboard outer container -->
        <FrameLayout
            android:layout_width="272dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_clipboard_board">

            <!-- Paper content area (inset, top space for clip) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="52dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:layout_marginBottom="14dp"
                android:orientation="vertical"
                android:background="@drawable/bg_clipboard_paper"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/tv_end_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DAY COMPLETE"
                    android:textColor="#3A2A00"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="10dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CC9922"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tv_end_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#3A2A00"
                    android:fontFamily="@font/inter"
                    android:textSize="14sp"
                    android:lineSpacingExtra="5dp"
                    android:paddingBottom="16dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_end_action"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="NEXT DAY"
                    android:background="@drawable/btn_approve"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/courier_prime"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:stateListAnimator="@null" />

            </LinearLayout>

            <!-- Metal clip assembly — centered at top -->
            <FrameLayout
                android:layout_width="76dp"
                android:layout_height="46dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp">

                <!-- Clip knob (round cap at top) -->
                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|center_horizontal"
                    android:background="@drawable/bg_clip_knob" />

                <!-- Clip grip bar -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="22dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:background="@drawable/bg_clip_bar" />

            </FrameLayout>

        </FrameLayout>
    </FrameLayout>

</FrameLayout>
