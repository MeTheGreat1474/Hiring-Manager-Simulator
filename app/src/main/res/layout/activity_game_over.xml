<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFAB76">

    <!-- ── TOP-LEFT: Laptop ── -->
    <ImageView
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="-30dp"
        android:layout_marginTop="-20dp"
        android:src="@drawable/ic_laptop"
        android:rotation="-15"
        android:scaleType="fitCenter"
        android:contentDescription="laptop" />

    <!-- ── TOP-RIGHT: Coffee cup ── -->
    <ImageView
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_coffee"
        android:rotation="10"
        android:scaleType="fitCenter"
        android:contentDescription="coffee" />

    <!-- ── BOTTOM-LEFT: Notebook ── -->
    <ImageView
        android:layout_width="160dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-10dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_notebook"
        android:rotation="10"
        android:scaleType="fitCenter"
        android:contentDescription="notebook" />

    <!-- ── BOTTOM-RIGHT: Pen, pencil, sticky notes ── -->
    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="-10dp"
        android:layout_marginBottom="10dp"
        android:src="@drawable/ic_pen_pencil"
        android:rotation="-5"
        android:scaleType="fitCenter"
        android:contentDescription="stationery" />

    <!-- ── CENTER: Clipboard ── -->
    <FrameLayout
        android:layout_width="260dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_clipboard_board">

        <!-- Cream paper -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="54dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_clipboard_paper"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- GAME OVER title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GAME OVER"
                android:textColor="#C0392B"
                android:fontFamily="@font/courier_prime"
                android:textSize="28sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="16dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CC9922"
                android:layout_marginBottom="14dp" />

            <!-- Stats -->
            <TextView
                android:id="@+id/tv_game_over_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#3A2A00"
                android:fontFamily="@font/inter"
                android:textSize="15sp"
                android:lineSpacingExtra="5dp"
                android:paddingBottom="24dp" />

            <!-- Play Again button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_play_again"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="PLAY AGAIN"
                android:background="@drawable/btn_approve"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/courier_prime"
                android:textSize="17sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:letterSpacing="0.08" />

        </LinearLayout>

        <!-- Metal clip assembly -->
        <FrameLayout
            android:layout_width="76dp"
            android:layout_height="46dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="8dp">

            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="top|center_horizontal"
                android:background="@drawable/bg_clip_knob" />

            <View
                android:layout_width="match_parent"
                android:layout_height="22dp"
                android:layout_gravity="bottom|center_horizontal"
                android:background="@drawable/bg_clip_bar" />

        </FrameLayout>

    </FrameLayout>

</FrameLayout>
